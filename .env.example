# Salin ke .env untuk pengembangan lokal. JANGAN commit .env berisi secret asli.

# Nama service (dipakai di tracing & log)
SERVER_NAME=go-boilerplate

# Alamat listen HTTP
HTTP_PORT=:8080

# Wajib. Koneksi Postgres.
DATABASE_URL=postgres://user:password@localhost:5432/dbname?sslmode=disable

# Wajib. Koneksi Redis (rate limiter + cache + queue Asynq — dipakai bersama).
REDIS_URL=redis://localhost:6379/0

# Worker: jumlah task yang diproses paralel.
WORKER_CONCURRENCY=10

# OpenTelemetry tracing. OTEL_ENABLED=false untuk mematikan middleware & tracer.
OTEL_ENABLED=true
# Endpoint OTLP collector untuk traces (dipakai bila OTEL_ENABLED=true).
OTLP_ENDPOINT=http://localhost:4318

# Rate limit: RATE_LIMIT_ENABLED=false untuk mematikan.
RATE_LIMIT_ENABLED=true
RATE_LIMIT=100
RATE_WINDOW=1m
